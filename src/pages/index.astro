---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Home"
  description="Yusuke Tamura - Web Developer Portfolio / 田村優典 - Webデベロッパーのポートフォリオサイト"
>
  <!-- Hero Section -->
  <section class="hero" id="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <div class="hero-badge reveal">
          <span class="badge-dot"></span>
          <span class="lang-en">🧑‍🎓 Student & Developer</span>
          <span class="lang-ja">🧑‍🎓 学生 兼 エンジニア</span>
        </div>
        <h1 class="hero-title reveal">
          <span class="lang-en"
            >Hi, I'm <br class="mobile-only" /><span class="gradient-text"
              >Yusuke Tamura</span
            > 🤓</span
          >
          <span class="lang-ja"
            >こんにちは、<br /><span class="gradient-text">田村優典</span>です
            🤓</span
          >
        </h1>
        <p class="hero-description reveal">
          <span class="lang-en">
            CS Student in Kyoto, Japan 🇯🇵 <br />
            Currently working with axcira 🐬<br />
            Mainly focusing on web development 💻
          </span>
          <span class="lang-ja">
            京都で情報学を専攻している学生です 🇯🇵 <br />
            現在 axcira というチームで開発を行っています 🐬<br />
            主にWebアプリケーションの開発に注力しています 💻
          </span>
        </p>
        <div class="hero-actions reveal">
          <a href="/works" class="btn btn-primary">
            <span class="lang-en">View Works</span>
            <span class="lang-ja">制作実績を見る</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M3 8h10M9 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
          <a href="/career" class="btn btn-secondary">
            <span class="lang-en">View Career</span>
            <span class="lang-ja">経歴を見る</span>
          </a>
        </div>
        <div class="hero-stats reveal">
          <div class="stat">
            <span class="stat-number">💻</span>
            <span class="stat-label">Web Dev</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-number">🐬</span>
            <span class="stat-label">axcira</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-number">🧑‍🎓</span>
            <span class="stat-label">Student</span>
          </div>
        </div>
      </div>
      <div class="hero-visual reveal">
        <div class="avatar-wrapper">
          <div class="avatar-glow"></div>
          <img
            src="/naughty8020icon.jpeg"
            alt="Yusuke Tamura"
            class="avatar-img"
            width="380"
            height="380"
          />
          <div class="avatar-ring"></div>
        </div>
        <!-- Floating tech badges -->
        <div class="floating-badge badge-1">
          <i class="devicon-react-original colored"></i> React
        </div>
        <div class="floating-badge badge-2">
          <i class="devicon-astro-plain colored"></i> Astro
        </div>
        <div class="floating-badge badge-3">
          <i class="devicon-nextjs-original colored"></i> Next.js
        </div>
        <div class="floating-badge badge-4">
          <i class="devicon-typescript-plain colored"></i> TypeScript
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section about-section" id="about">
    <div class="container">
      <span class="section-label reveal">
        <span class="lang-en">About Me</span>
        <span class="lang-ja">自己紹介</span>
      </span>
      <h2 class="section-title reveal">
        <span class="lang-en">About Me</span>
        <span class="lang-ja">私について</span>
      </h2>
      <div class="about-grid">
        <div class="about-content reveal">
          <p class="about-text">
            <span class="lang-en"
              >I am a student currently attending a school in Kyoto, Japan 🧑‍🎓</span
            >
            <span class="lang-ja">私は現在、京都の学校に通う学生です 🧑‍🎓</span>
          </p>
          <p class="about-text">
            <span class="lang-en">
              I am also working on contract development as part of a team called
              axcira 🐬. My main focus is on web development, where I enjoy
              building applications and learning new technologies to hone my
              skills.
            </span>
            <span class="lang-ja">
              また、「axcira」🐬 というチームで受託開発にも携わっています。
              主にWebアプリケーション開発に注力しており、Typescript,Python,Kotlin,Goなどを利用して開発を行っています。
            </span>
          </p>
        </div>
        <div class="about-cards reveal">
          <div class="info-card">
            <div class="info-icon">📍</div>
            <div>
              <p class="info-label">
                <span class="lang-en">Location</span>
                <span class="lang-ja">居住地</span>
              </p>
              <p class="info-value">
                <span class="lang-en">Kyoto, Japan 🇯🇵</span>
                <span class="lang-ja">京都府 🇯🇵</span>
              </p>
            </div>
          </div>
          <div class="info-card">
            <div class="info-icon">🐬</div>
            <div>
              <p class="info-label">
                <span class="lang-en">Work</span>
                <span class="lang-ja">所属</span>
              </p>
              <p class="info-value">axcira</p>
            </div>
          </div>
          <div class="info-card">
            <div class="info-icon">🧑‍🎓</div>
            <div>
              <p class="info-label">
                <span class="lang-en">Status</span>
                <span class="lang-ja">ステータス</span>
              </p>
              <p class="info-value">
                <span class="lang-en">Student</span>
                <span class="lang-ja">学生</span>
              </p>
            </div>
          </div>
          <div class="info-card">
            <div class="info-icon">💻</div>
            <div>
              <p class="info-label">
                <span class="lang-en">Focus</span>
                <span class="lang-ja">専門分野</span>
              </p>
              <p class="info-value">
                <span class="lang-en">Web Development</span>
                <span class="lang-ja">Web開発</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Links Section -->
  <section class="section quick-section">
    <div class="container">
      <div class="quick-grid">
        <a href="/career" class="quick-card glass-card reveal">
          <div class="quick-icon">📋</div>
          <h3 class="quick-title">
            <span class="lang-en">Career</span>
            <span class="lang-ja">経歴</span>
          </h3>
          <p class="quick-desc">
            <span class="lang-en">View my background and experience</span>
            <span class="lang-ja">これまでの経歴や経験を確認する</span>
          </p>
          <span class="quick-arrow">→</span>
        </a>
        <a href="/techstack" class="quick-card glass-card reveal">
          <div class="quick-icon">⚡</div>
          <h3 class="quick-title">
            <span class="lang-en">Tech Stack</span>
            <span class="lang-ja">スキル</span>
          </h3>
          <p class="quick-desc">
            <span class="lang-en">Check out my technical skills</span>
            <span class="lang-ja">習得している技術スタックを見る</span>
          </p>
          <span class="quick-arrow">→</span>
        </a>
        <a href="/works" class="quick-card glass-card reveal">
          <div class="quick-icon">🎨</div>
          <h3 class="quick-title">
            <span class="lang-en">Works</span>
            <span class="lang-ja">実績</span>
          </h3>
          <p class="quick-desc">
            <span class="lang-en">Explore my past projects</span>
            <span class="lang-ja">過去に制作したプロジェクトを見る</span>
          </p>
          <span class="quick-arrow">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ============================================
     Hero
     ============================================ */
  .hero {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    padding: 60px 0 80px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    background: rgba(0, 180, 166, 0.08);
    border: 1px solid rgba(0, 180, 166, 0.2);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent-2);
    margin-bottom: 28px;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent-2);
    border-radius: 50%;
    display: inline-block;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 0 0 rgba(0, 180, 166, 0.3);
    }
    50% {
      opacity: 0.6;
      box-shadow: 0 0 0 8px rgba(0, 180, 166, 0);
    }
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.25;
    margin-bottom: 24px;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  .mobile-only {
    display: none;
  }
  @media (max-width: 480px) {
    .mobile-only {
      display: block;
    }
  }

  .hero-description {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.9;
    margin-bottom: 36px;
    max-width: 520px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .stat-number {
    display: block;
    font-size: 1.8rem;
    font-weight: 800;
    background: var(--color-accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
    display: block;
    margin-top: 4px;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* Hero Visual */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 380px;
  }

  .avatar-wrapper {
    position: relative;
    width: 340px;
    height: 340px;
  }

  .avatar-glow {
    position: absolute;
    inset: -20px;
    background: var(--color-accent-gradient);
    border-radius: 50%;
    opacity: 0.12;
    filter: blur(40px);
    animation: glowPulse 4s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%,
    100% {
      opacity: 0.12;
      transform: scale(1);
    }
    50% {
      opacity: 0.22;
      transform: scale(1.05);
    }
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid rgba(0, 0, 0, 0.06);
    position: relative;
    z-index: 1;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .avatar-ring {
    position: absolute;
    inset: -12px;
    border: 2px dashed rgba(0, 102, 255, 0.3);
    border-radius: 50%;
    animation: spin 30s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .floating-badge {
    position: absolute;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-primary);
    white-space: nowrap;
    z-index: 2;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .badge-1 {
    top: 10%;
    right: -10%;
    animation: floatBadge1 6s ease-in-out infinite;
  }

  .badge-2 {
    bottom: 15%;
    right: -5%;
    animation: floatBadge2 6s ease-in-out infinite;
  }

  .badge-3 {
    top: 20%;
    left: -15%;
    animation: floatBadge3 6s ease-in-out infinite;
  }

  .badge-4 {
    bottom: 5%;
    left: -10%;
    animation: floatBadge4 6s ease-in-out infinite;
  }

  @keyframes floatBadge1 {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  @keyframes floatBadge2 {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }
  @keyframes floatBadge3 {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }
  @keyframes floatBadge4 {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-14px);
    }
  }

  /* ============================================
     About Section
     ============================================ */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    margin-top: 32px;
  }

  .about-text {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 2;
    margin-bottom: 20px;
  }

  .about-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 20px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .info-card:hover {
    background: var(--color-bg-card-hover);
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .info-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .info-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .info-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  /* ============================================
     Quick Links
     ============================================ */
  .quick-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .quick-card {
    text-align: center;
    padding: 48px 32px;
    position: relative;
    overflow: hidden;
    display: block;
  }

  .quick-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--color-accent-gradient);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .quick-card:hover::before {
    opacity: 1;
  }

  .quick-icon {
    font-size: 2.5rem;
    margin-bottom: 20px;
    line-height: 1;
  }

  .quick-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--color-text-primary);
  }

  .quick-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .quick-arrow {
    display: inline-block;
    font-size: 1.2rem;
    color: var(--color-accent-2);
    transition: transform var(--transition-fast);
  }

  .quick-card:hover .quick-arrow {
    transform: translateX(6px);
  }

  /* ============================================
     Responsive
     ============================================ */
  @media (max-width: 968px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      text-align: center;
    }

    .hero-description {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
      min-height: 280px;
    }

    .avatar-wrapper {
      width: 260px;
      height: 260px;
    }

    .floating-badge {
      display: none;
    }

    .about-grid {
      grid-template-columns: 1fr;
    }

    .quick-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-stats {
      gap: 20px;
    }

    .stat-number {
      font-size: 1.4rem;
    }

    .about-cards {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
