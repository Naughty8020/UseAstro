---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: "Analytics Dashboard",
    description: "リアルタイムデータ分析ダッシュボード。売上データやユーザーアクティビティを可視化する管理画面を開発。インタラクティブなチャートとグラフを実装。",
    image: "/project-dashboard.png",
    tags: ["React", "TypeScript", "Chart.js", "Tailwind CSS"],
    category: "Web App",
    link: "#",
    github: "#",
    featured: true,
  },
  {
    title: "E-Commerce Platform",
    description: "ラグジュアリーブランド向けECサイト。商品管理、カート、決済機能を実装。レスポンシブデザインとアニメーションにこだわったUI。",
    image: "/project-ecommerce.png",
    tags: ["Next.js", "Stripe", "Prisma", "PostgreSQL"],
    category: "EC Site",
    link: "#",
    github: "#",
    featured: true,
  },
  {
    title: "Tech Blog Platform",
    description: "開発者向けの技術ブログプラットフォーム。Markdownエディタ、タグ管理、シンタックスハイライト機能を実装。SEO最適化済み。",
    image: "/project-blog.png",
    tags: ["Astro", "MDX", "Tailwind CSS"],
    category: "Blog",
    link: "#",
    github: "#",
    featured: false,
  },
];
---

<BaseLayout title="Works" description="田村祐介の成果物・プロジェクト一覧">

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label reveal">Works</span>
      <h1 class="section-title reveal">成果物・プロジェクト</h1>
      <p class="section-subtitle reveal">
        これまでに手がけたプロジェクトの一部をご紹介します。<br />
        設計から実装まで、一貫して品質にこだわっています。
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid reveal">
        <div class="stat-card glass-card">
          <span class="stat-num gradient-text">10+</span>
          <span class="stat-lbl">Total Projects</span>
        </div>
        <div class="stat-card glass-card">
          <span class="stat-num gradient-text">3</span>
          <span class="stat-lbl">Featured Works</span>
        </div>
        <div class="stat-card glass-card">
          <span class="stat-num gradient-text">5+</span>
          <span class="stat-lbl">Technologies Used</span>
        </div>
        <div class="stat-card glass-card">
          <span class="stat-num gradient-text">100%</span>
          <span class="stat-lbl">Passion</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="section projects-section">
    <div class="container">
      <span class="section-label reveal">Projects</span>
      <h2 class="section-title reveal">プロジェクト一覧</h2>

      <div class="projects-grid">
        {projects.map((project, index) => (
          <div class:list={["project-card reveal", { "project-featured": project.featured }]}>
            <div class="project-image-wrapper">
              <img
                src={project.image}
                alt={project.title}
                class="project-image"
                loading="lazy"
                width="600"
                height="400"
              />
              <div class="project-overlay">
                <div class="project-actions">
                  <a href={project.link} class="action-btn" target="_blank" rel="noopener noreferrer">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
                    </svg>
                    Live Demo
                  </a>
                  <a href={project.github} class="action-btn action-btn-outline" target="_blank" rel="noopener noreferrer">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                    GitHub
                  </a>
                </div>
              </div>
              <span class="project-category">{project.category}</span>
            </div>
            <div class="project-info">
              <h3 class="project-title">{project.title}</h3>
              <p class="project-desc">{project.description}</p>
              <div class="project-tags">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-card glass-card reveal">
        <div class="cta-content">
          <h2 class="cta-title">一緒にプロジェクトを<span class="gradient-text">始めませんか？</span></h2>
          <p class="cta-desc">新しいプロジェクトのご相談、お待ちしています。お気軽にご連絡ください。</p>
          <div class="cta-actions">
            <a href="mailto:contact@example.com" class="btn btn-primary">
              <span>お問い合わせ</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">GitHub</a>
          </div>
        </div>
        <div class="cta-decoration">
          <div class="cta-circle"></div>
          <div class="cta-circle cta-circle-2"></div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* ============================================
     Stats Bar
     ============================================ */
  .stats-bar {
    padding: 20px 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .stat-card {
    text-align: center;
    padding: 28px 20px;
  }

  .stat-num {
    display: block;
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 6px;
    line-height: 1.2;
  }

  .stat-lbl {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    display: block;
  }

  /* ============================================
     Projects Grid
     ============================================ */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    margin-top: 40px;
  }

  .project-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-medium);
  }

  .project-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-6px);
    box-shadow: var(--shadow-glow);
  }

  .project-featured {
    grid-column: span 1;
  }

  .project-featured:first-child {
    grid-column: span 2;
  }

  .project-image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .project-featured:first-child .project-image-wrapper {
    aspect-ratio: 21 / 9;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .project-card:hover .project-image {
    transform: scale(1.05);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 46, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-medium);
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-actions {
    display: flex;
    gap: 12px;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--color-accent-gradient);
    color: white;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 600;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .action-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(108, 92, 231, 0.4);
  }

  .action-btn-outline {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .action-btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    box-shadow: none;
  }

  .project-category {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 6px 14px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent-1);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    z-index: 1;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .project-info {
    padding: 28px;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 12px;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ============================================
     CTA Section
     ============================================ */
  .cta-card {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 80px 40px;
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 16px;
    line-height: 1.4;
  }

  .cta-desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-bottom: 32px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.8;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-decoration {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-circle {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: rgba(108, 92, 231, 0.08);
    top: -100px;
    right: -80px;
  }

  .cta-circle-2 {
    width: 250px;
    height: 250px;
    background: rgba(0, 206, 201, 0.06);
    top: auto;
    right: auto;
    bottom: -80px;
    left: -60px;
  }

  /* ============================================
     Responsive
     ============================================ */
  @media (max-width: 968px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .project-featured:first-child {
      grid-column: span 1;
    }

    .project-featured:first-child .project-image-wrapper {
      aspect-ratio: 16 / 10;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .cta-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
